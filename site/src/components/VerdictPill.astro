---
import { VERDICTS, VERDICT_KEY, type Verdict } from "../lib/verdicts";

interface Props {
  verdict: Verdict;
  size?: "sm" | "md" | "lg";
  showDescription?: boolean;
}

const { verdict, size = "md", showDescription = false } = Astro.props;
const v = VERDICTS[verdict];
const key = VERDICT_KEY[verdict];

const padding = {
  sm: "0.18rem 0.55rem",
  md: "0.25rem 0.7rem 0.3rem",
  lg: "0.32rem 0.85rem 0.36rem",
}[size];
const fs = { sm: "0.6875rem", md: "0.75rem", lg: "0.8125rem" }[size];
---

<span style="display:inline-flex;flex-direction:column;align-items:flex-start;gap:0.25rem;">
  <span class="verdict-pill" data-v={key} style={`padding:${padding};font-size:${fs};`}>
    {v.label}
  </span>
  {showDescription && (
    <span class="ui" style="color:var(--ink-sub);font-style:italic;font-family:var(--serif);font-size:0.8125rem;">
      {v.description}
    </span>
  )}
</span>
