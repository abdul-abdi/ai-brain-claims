---
import { NAV, SITE, u, BASE } from "../lib/site";
const path = Astro.url.pathname;
---

<header class="border-b border-ink-400/20 bg-bone-100/85 backdrop-blur-sm sticky top-0 z-30">
  <nav class="mx-auto flex max-w-wide items-center justify-between px-6 py-4 lg:px-12 font-sans text-sm">
    <a href={u("/")} class="flex items-baseline gap-2 text-ink-900 no-underline">
      <span class="font-serif text-lg font-medium">10 Claims</span>
      <span class="hidden text-ink-500 sm:inline">at the Frontier</span>
    </a>

    <ul class="flex items-center gap-1 sm:gap-2">
      {NAV.map((item) => {
        const isExternal = "external" in item && item.external;
        const resolvedHref = isExternal ? item.href : u(item.href);
        const stripped = path.replace(BASE, "") || "/";
        const linkPath = item.href.split("#")[0] || "/";
        const active = !isExternal && (
          stripped === linkPath ||
          (linkPath !== "/" && stripped.startsWith(linkPath))
        );
        return (
          <li>
            <a
              href={resolvedHref}
              class={`rounded px-3 py-1.5 no-underline transition-colors ${
                active
                  ? "bg-bone-200 text-ink-900"
                  : "text-ink-600 hover:bg-bone-200 hover:text-ink-900"
              }`}
              {...(isExternal ? { target: "_blank", rel: "noopener" } : {})}
            >
              {item.label}
              {isExternal && <span aria-hidden="true" class="ml-1 text-xs">↗</span>}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
