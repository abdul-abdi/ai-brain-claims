---
import { NAV, BASE, u } from "../lib/site";

const path = Astro.url.pathname;
const stripped = path.replace(BASE, "") || "/";

function isActive(href: string): boolean {
  const linkPath = href.split("#")[0] || "/";
  if (linkPath === "/") return stripped === "/";
  if (linkPath.startsWith("/claims")) return stripped.startsWith("/claims");
  return stripped === linkPath || stripped.startsWith(linkPath + "/");
}
---

<nav class="topnav" aria-label="Primary">
  <a class="brand" href={u("/")}>
    Ten Claims at the Frontier <em>· a working notebook</em>
  </a>
  {NAV.map((item) => {
    const ext = "external" in item && item.external;
    const href = ext ? item.href : u(item.href);
    const active = !ext && isActive(item.href);
    return (
      <a
        href={href}
        class={active ? "active" : ""}
        {...(ext ? { target: "_blank", rel: "noopener" } : {})}
      >
        {item.label}
      </a>
    );
  })}
</nav>
