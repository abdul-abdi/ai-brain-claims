---
import VerdictPill from "./VerdictPill.astro";
import type { ClaimSummary } from "../lib/verdicts";

interface Props {
  claim: ClaimSummary;
  showThread?: boolean;
}

const { claim, showThread = true } = Astro.props;
const numStr = String(claim.number).padStart(2, "0");
---

<a
  href={`/claims/${claim.id}`}
  class="group block rounded-lg border border-ink-400/20 bg-bone-50 p-6 no-underline transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/50 hover:shadow-[0_8px_30px_-12px_rgba(204,120,92,0.18)]"
>
  <div class="flex items-baseline justify-between gap-3">
    <span class="font-mono text-sm text-ink-500">Claim {numStr}</span>
    <VerdictPill verdict={claim.verdict} size="sm" />
  </div>

  <h3 class="mt-3 font-serif text-xl font-medium leading-snug text-ink-900 transition-colors group-hover:text-accent-700">
    {claim.title}
  </h3>

  <div class="mt-4 space-y-3 text-sm leading-relaxed text-ink-700">
    <p>
      <span class="font-sans text-[0.7rem] font-medium uppercase tracking-wider text-verdict-vindicated">For</span>
      <span class="ml-2">{claim.oneLineFor}</span>
    </p>
    <p>
      <span class="font-sans text-[0.7rem] font-medium uppercase tracking-wider text-verdict-refuted">Against</span>
      <span class="ml-2">{claim.oneLineAgainst}</span>
    </p>
  </div>

  <div class="mt-5 flex items-center justify-between border-t border-ink-400/15 pt-4 font-sans text-xs text-ink-500">
    <span>Lenses: {claim.personas.join(" + ")}</span>
    {showThread && <span class="capitalize">{claim.thread}</span>}
  </div>
</a>
