---
import BaseLayout from "../layouts/BaseLayout.astro";
import { READING_LIST, ALL_REFS, type VerificationStatus } from "../lib/reading-list";

const loadBearingCount = ALL_REFS.filter((r) => r.loadBearing).length;
const verifiedCount = ALL_REFS.filter((r) => r.verification === "verified").length;
const correctionCount = ALL_REFS.filter((r) => r.verification === "verified-with-correction").length;
const byNameCount = ALL_REFS.filter((r) => r.verification === "verified-by-name").length;

const STATUS_LABEL: Record<VerificationStatus, { label: string; color: string; title: string }> = {
  "verified": {
    label: "verified",
    color: "var(--v-vindicated)",
    title: "Re-fetched from arXiv on 2026-05-10. Title and authors confirmed.",
  },
  "verified-with-correction": {
    label: "corrected",
    color: "var(--v-contested)",
    title: "Re-fetched from arXiv. An earlier draft had a wrong title or attribution; corrected in place.",
  },
  "verified-by-name": {
    label: "by-name",
    color: "var(--v-plausible)",
    title: "Older / well-established work, not WebFetched but cited by title and author search.",
  },
  "unverified": {
    label: "unverified",
    color: "var(--v-refuted)",
    title: "Not yet checked.",
  },
};
---

<BaseLayout
  title="Reading list"
  description="The 25 most load-bearing primary sources across all 10 dossiers, organized by thread."
  wave="research"
>
  <main class="reading-list">
    <div class="tracked">Reading list · {ALL_REFS.length} sources · {loadBearingCount} load-bearing</div>
    <h1 style="margin-top:0.75rem;margin-bottom:1rem;">What the dossiers cited.</h1>
    <p style="max-width:65ch;color:var(--ink-sub);">
      Sorted by <em>provenance density</em> &mdash; how many of the ten dossiers cite the same paper. The load-bearing papers (★) are the structure of the entire session: where the dossiers agree on what to read, even when they disagree on what it means.
    </p>
    <p style="margin-top:1rem;font-family:var(--sans);font-size:.75rem;color:var(--ink-sub);display:flex;flex-wrap:wrap;gap:.6rem;">
      <span style="color:var(--ink-mute);">Verification status (re-fetched 2026-05-10):</span>
      <span style="color:var(--v-vindicated);">verified · {verifiedCount}</span>
      <span style="color:var(--v-contested);">corrected · {correctionCount}</span>
      <span style="color:var(--v-plausible);">by-name · {byNameCount}</span>
    </p>

    {READING_LIST.map((thread) => (
      <section style="margin-top:3rem;">
        <div class="tracked">Thread</div>
        <h2 style="margin-top:.5rem;font-size:1.5rem;">{thread.label}</h2>
        <p style="color:var(--ink-sub);margin-top:.5rem;max-width:65ch;">{thread.description}</p>

        <div style="margin-top:2rem;">
          {thread.refs.map((ref) => {
            const href = ref.link
              ? ref.link
              : ref.arxiv
                ? `https://arxiv.org/abs/${ref.arxiv}`
                : ref.doi
                  ? `https://doi.org/${ref.doi}`
                  : null;
            const provLevel = ref.loadBearing ? 6 : 3;
            const status = STATUS_LABEL[ref.verification];
            return (
              <div class="cite-row">
                <span class="yr">{ref.year}</span>
                <span class="ttl">
                  {ref.loadBearing && <span style="color:var(--accent);margin-right:.3em;">★</span>}
                  {href ? (
                    <a href={href} target="_blank" rel="noopener" style="border-bottom:1px solid var(--accent);">
                      <em>{ref.title}</em>
                    </a>
                  ) : (
                    <em>{ref.title}</em>
                  )}
                  <small>{ref.authors} · {ref.venue}{ref.arxiv && ` · arXiv:${ref.arxiv}`}</small>
                  <small style="color:var(--ink-mute);font-style:italic;">{ref.annotation}</small>
                </span>
                <span class="prov" aria-label={`provenance density: ${provLevel} of 6`}>
                  {Array.from({ length: 6 }).map((_, j) => (
                    <span class={"seg" + (j < provLevel ? " on" : "")} />
                  ))}
                </span>
                <span class="verify" style={`color:${status.color};border-color:currentColor;`} title={status.title}>
                  {status.label}
                </span>
              </div>
            );
          })}
        </div>
      </section>
    ))}

    <section style="margin-top:4rem;border-top:1px solid var(--bone-line);padding-top:2rem;">
      <div class="tracked">A note on verification</div>
      <p style="color:var(--ink-sub);max-width:65ch;margin-top:.75rem;">
        Each citation tagged <strong style="color:var(--ink);">verified</strong> was re-fetched from arXiv on 2026-05-10 and the title and authors were confirmed against the site source. Tagged <strong style="color:var(--ink);">corrected</strong> means the re-fetch surfaced an attribution error in an earlier draft; the entry has been fixed in place. Tagged <strong style="color:var(--ink);">by-name</strong> are older, well-cited works not WebFetched but uniquely identifiable by title + author search.
      </p>
      <p style="color:var(--ink-sub);max-width:65ch;margin-top:1rem;">
        Two corrections worth flagging: <strong style="color:var(--ink);">Granier &amp; Senn 2025</strong>'s actual title is "Multihead self-attention in cortico-thalamic circuits", and <strong style="color:var(--ink);">Butlin et al. 2023</strong> on consciousness in AI does not include David Chalmers as an author — it does include Yoshua Bengio, Jonathan Birch, Chris Frith, and others.
      </p>
    </section>
  </main>
</BaseLayout>
