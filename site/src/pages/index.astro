---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ClaimsExplorer } from "../components/ClaimsExplorer";
import { CLAIMS, THREADS, VERDICT_KEY } from "../lib/verdicts";
import { SITE, BASE, u } from "../lib/site";
---

<BaseLayout wave="home">
  <ClaimsExplorer claims={CLAIMS} base={BASE} client:load />

  <!-- Cross-cutting threads -->
  <section style="padding:clamp(3rem,6vh,5rem) clamp(1rem,4vw,3rem);border-bottom:1px solid var(--bone-line);">
    <div class="tracked">Threads</div>
    <h2 style="margin-top:.6rem;max-width:36ch;">Four convergent threads.</h2>
    <p class="sub" style="color:var(--ink-sub);max-width:65ch;margin-top:.5rem;">
      The ten claims sort into four convergent threads. Each thread carries an engineering recommendation that survived adversarial review.
    </p>
    <div style="display:grid;gap:1.25rem;margin-top:2.25rem;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));">
      {Object.entries(THREADS).map(([key, thread]) => (
        <article class="note-card">
          <div class="tracked">Thread · {key}</div>
          <h3 style="margin:.5rem 0 .5rem 0;">{thread.label}</h3>
          <p style="color:var(--ink-sub);margin-bottom:1rem;">{thread.description}</p>
          <div style="display:flex;flex-wrap:wrap;gap:.4rem;">
            {thread.claims.map((n) => {
              const c = CLAIMS.find((x) => x.number === n)!;
              return (
                <a
                  href={u(`/claims/${c.id}`)}
                  class="claim-chip"
                  style={`--bg:var(--v-${VERDICT_KEY[c.verdict]});`}
                >
                  <span class="num">{String(n).padStart(2, "0")}</span>
                  <span class="dot"></span>
                  <span>{c.shortTitle}</span>
                </a>
              );
            })}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Observatory pitch -->
  <section style="padding:clamp(3rem,6vh,5rem) clamp(1rem,4vw,3rem);border-bottom:1px solid var(--bone-line);">
    <div class="tracked">Wave 3 · The Observatory</div>
    <h2 style="margin-top:.5rem;">The benchmark, with handles.</h2>
    <div style="display:grid;gap:2rem;grid-template-columns:1fr;margin-top:2rem;align-items:start;" class="obs-pitch">
      <div>
        <p style="color:var(--ink-sub);max-width:60ch;">
          The research's strongest engineering surface — agent context as an immutable event log with importance and confidence as pure functions over the log — packaged as a Python primitive you can install and run.
        </p>
        <p style="color:var(--ink-sub);max-width:60ch;">
          Different scorers can be A/B'd against the same historical log. Failure modes become deterministically replayable. The eval harness extends NVIDIA RULER with hygiene-aware metrics.
        </p>
        <div style="margin-top:1.5rem;display:flex;flex-wrap:wrap;gap:.6rem;font-family:var(--sans);font-size:.8125rem;">
          <a href={u("/observatory")} style="border:1px solid var(--ink);padding:.45rem .8rem;color:var(--ink);">Read the design →</a>
          <a href={SITE.repo} target="_blank" rel="noopener" style="border:1px solid var(--bone-line);padding:.45rem .8rem;">GitHub ↗</a>
        </div>
      </div>
      <pre style="margin:0;"><code>{`# install
pip install claim-observatory

# usage
from observatory import EventLog, view, importance

log = EventLog()
log.append({"role": "user", "content": "..."})
log.append({"role": "assistant", "content": "..."})
log.append({"role": "tool", "name": "search", "content": "..."})

# tier membership is a derived view, not a stored place
working = view(
    log,
    scorer=importance.recency_attention(),
    window=4096,
)

# A/B test scorers against the same log — deterministic replay
alt = view(log, scorer=importance.task_relevance(query="..."), window=4096)
delta = compare(working, alt)
`}</code></pre>
    </div>
  </section>

  <!-- How to read -->
  <section style="padding:clamp(3rem,6vh,5rem) clamp(1rem,4vw,3rem);">
    <div class="tracked">Three ways in</div>
    <h2 style="margin-top:.5rem;">How to read this notebook.</h2>
    <div style="display:grid;gap:1.25rem;margin-top:2rem;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));">
      {[
        { time: "10 min", who: "Read the synthesis only.", href: "/synthesis", tag: "Skim" },
        { time: "1 hour", who: "Synthesis + the 3–4 claims most relevant to your work.", href: "/", tag: "Survey" },
        { time: "3 hours", who: "All ten dossiers in order, plus the curated reading list.", href: "/reading-list", tag: "Deep" },
      ].map(({ time, who, href, tag }) => (
        <a href={u(href)} class="note-card" style="display:block;color:var(--ink);border-bottom:1px solid var(--bone-line);">
          <div class="tracked" style="color:var(--accent);">{tag}</div>
          <p style="font-family:var(--serif);font-size:1.875rem;margin:.5rem 0 .5rem 0;font-weight:450;">{time}</p>
          <p style="color:var(--ink-sub);margin-bottom:1rem;">{who}</p>
          <span style="font-family:var(--sans);font-size:.8125rem;color:var(--accent);">Continue →</span>
        </a>
      ))}
    </div>
  </section>

  <style>
    @media (min-width: 980px) {
      .obs-pitch { grid-template-columns: 1fr 1.2fr !important; }
    }
  </style>
</BaseLayout>
