---
import BaseLayout from "../layouts/BaseLayout.astro";
import { BASE } from "../lib/site";

const pagefindBase = `${BASE}/pagefind/`;
---

<BaseLayout
  title="Search"
  description="Search across all 10 claim dossiers, the synthesis, the observatory, and the reading list."
>
  <article class="mx-auto max-w-prose px-6 py-12 lg:py-20">
    <header>
      <p class="font-sans text-xs uppercase tracking-[0.18em] text-ink-500">Pagefind index</p>
      <h1 class="mt-4 font-serif text-4xl font-medium leading-[1.1] tracking-[-0.01em] text-ink-900 lg:text-5xl">
        Search
      </h1>
      <p class="mt-5 font-serif text-prose-lg leading-relaxed text-ink-700">
        The 15-page corpus is indexed at build time by <a href="https://pagefind.app" target="_blank" rel="noopener">Pagefind</a>. Static, no server, ~25 KB index, fully keyboard-navigable.
      </p>
    </header>

    <div id="search" class="mt-12"></div>

    <p class="mt-12 font-sans text-sm italic text-ink-500">
      Tip: try <code>"persona vectors"</code>, <code>tip-of-the-tongue</code>, <code>importance scoring</code>, or <code>cortical column</code>.
    </p>
  </article>

  <link
    slot="head"
    href={`${pagefindBase}pagefind-ui.css`}
    rel="stylesheet"
  />

  <script is:inline define:vars={{ pagefindBase }}>
    window.__PAGEFIND_BASE__ = pagefindBase;
  </script>

  <script type="module">
    const base = window.__PAGEFIND_BASE__;
    // Pagefind UI is shipped alongside the index by astro-pagefind into /pagefind/
    const { PagefindUI } = await import(`${base}pagefind-ui.js`);
    new PagefindUI({
      element: "#search",
      bundlePath: base,
      showImages: false,
      showSubResults: true,
      excerptLength: 28,
      resetStyles: false,
      translations: {
        placeholder: "Search the corpus…",
        zero_results: "No matches for [SEARCH_TERM]. Try a broader query, or check the reading list.",
      },
    });
  </script>

  <style is:global>
    /* Tone Pagefind UI to match the site's warm-bone palette */
    :root {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: #cc785c;
      --pagefind-ui-text: #1a1714;
      --pagefind-ui-background: #fbfaf6;
      --pagefind-ui-border: rgba(168, 156, 136, 0.35);
      --pagefind-ui-tag: #ede7dc;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 0.5rem;
      --pagefind-ui-image-border-radius: 0.375rem;
      --pagefind-ui-image-box-ratio: 3 / 2;
      --pagefind-ui-font: "Inter", system-ui, sans-serif;
    }
    .pagefind-ui__search-input {
      font-family: "Source Serif 4", serif;
    }
    .pagefind-ui__result-title {
      font-family: "Source Serif 4", serif;
    }
  </style>
</BaseLayout>
