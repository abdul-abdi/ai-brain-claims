---
import BaseLayout from "../layouts/BaseLayout.astro";
import { BASE } from "../lib/site";

const pagefindBase = `${BASE}/pagefind/`;
---

<BaseLayout
  title="Search"
  description="Search across all 10 claim dossiers, the synthesis, the observatory, and the reading list."
  wave="research"
>
  <main class="prose-col">
    <div class="tracked">Pagefind index</div>
    <h1 style="margin-top:.5rem;">Search.</h1>
    <p class="lede" style="margin-top:1.25rem;color:var(--ink-sub);">
      The 15-page corpus is indexed at build time by <a href="https://pagefind.app" target="_blank" rel="noopener">Pagefind</a>. Static, no server, ~25 KB index, fully keyboard-navigable.
    </p>

    <div id="search" style="margin-top:2.5rem;"></div>

    <p style="margin-top:2rem;font-family:var(--sans);font-size:.8125rem;font-style:italic;color:var(--ink-sub);">
      Tip: try <code>persona vectors</code>, <code>tip-of-the-tongue</code>, <code>importance scoring</code>, or <code>cortical column</code>.
    </p>
  </main>

  <link slot="head" href={`${pagefindBase}pagefind-ui.css`} rel="stylesheet" />

  <script is:inline define:vars={{ pagefindBase }}>
    window.__PAGEFIND_BASE__ = pagefindBase;
  </script>

  <script type="module">
    const base = window.__PAGEFIND_BASE__;
    const { PagefindUI } = await import(`${base}pagefind-ui.js`);
    new PagefindUI({
      element: "#search",
      bundlePath: base,
      showImages: false,
      showSubResults: true,
      excerptLength: 28,
      resetStyles: false,
      translations: {
        placeholder: "Search the notebook…",
        zero_results:
          "No matches for [SEARCH_TERM]. Try a broader query, or check the reading list.",
      },
    });
  </script>

  <style is:global>
    :root {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: var(--accent);
      --pagefind-ui-text: var(--ink);
      --pagefind-ui-background: var(--bone);
      --pagefind-ui-border: var(--bone-line);
      --pagefind-ui-tag: var(--bone-muted);
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 2px;
      --pagefind-ui-image-border-radius: 0;
      --pagefind-ui-image-box-ratio: 3 / 2;
      --pagefind-ui-font: "Inter", system-ui, sans-serif;
    }
    .pagefind-ui__search-input { font-family: "Source Serif 4", serif; }
    .pagefind-ui__result-title  { font-family: "Source Serif 4", serif; }
  </style>
</BaseLayout>
